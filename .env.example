# ============================================
# GAME-LEARN ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.local and fill in your values
# Also create backend/.env.local and frontend/.env.local

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Server
BACKEND_PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/gamelearn
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/gamelearn

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# CORS - Allowed Origins for Frontend
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Service (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# File Uploads
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# External APIs (if needed)
GOOGLE_API_KEY=your_key_here

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API Endpoint
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=10000

# Application
VITE_APP_NAME=Game-Learn
VITE_APP_VERSION=1.0.0

# Features
VITE_ENABLE_MOCK_API=false
VITE_DEBUG_MODE=false

# Local Storage Keys
VITE_AUTH_TOKEN_KEY=auth_token
VITE_AUTH_USER_KEY=auth_user

